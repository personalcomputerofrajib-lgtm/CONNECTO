<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_bg"
    android:padding="20dp">

    <!-- TITLE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PAIN DETAILS"
        android:textColor="#00FFFF"
        android:textSize="14sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.2"
        android:layout_marginBottom="4dp"/>

    <!-- REGION LABEL -->
    <TextView
        android:id="@+id/dialogRegionName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Region"
        android:textColor="#00FFCC"
        android:textSize="13sp"
        android:background="@drawable/badge_bg"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:layout_marginBottom="16dp"/>

    <!-- PAIN TYPE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PAIN TYPE"
        android:textColor="#667799"
        android:textSize="11sp"
        android:layout_marginBottom="4dp"/>

    <Spinner
        android:id="@+id/spinnerPainType"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/btn_outline"
        android:paddingStart="10dp"
        android:layout_marginBottom="12dp"/>

    <!-- DURATION -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DURATION (e.g. 2 days)"
        android:textColor="#667799"
        android:textSize="11sp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etDuration"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/btn_outline"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:paddingStart="10dp"
        android:hint="e.g. 3 days"
        android:inputType="text"
        android:layout_marginBottom="12dp"/>

    <!-- NOTES -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NOTES (optional)"
        android:textColor="#667799"
        android:textSize="11sp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etNotes"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/btn_outline"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:paddingStart="10dp"
        android:hint="Additional context..."
        android:inputType="textMultiLine"
        android:gravity="top"
        android:layout_marginBottom="16dp"/>

    <!-- BUTTONS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancelPain"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="CANCEL"
            android:textColor="#667799"
            android:textSize="11sp"
            android:background="#0A0A1A"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnSavePain"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:text="SAVE"
            android:textColor="#000000"
            android:textSize="11sp"
            android:background="#00FFCC"/>

    </LinearLayout>

</LinearLayout>
