<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/hud_grid_bg">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PATIENT_DATA_ENTRY"
        android:textColor="#00FFFF"
        android:textSize="18sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.2"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintTop_toBottomOf="@id/title">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="REG_NAME:" android:textColor="#00FFCC" android:textSize="11sp" android:fontFamily="monospace"/>
        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="[Patient_ID]"
            android:textColor="#FFFFFF"
            android:textColorHint="#446677"
            android:background="@drawable/btn_outline"
            android:paddingStart="12dp"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AGE_VAL:" android:textColor="#00FFCC" android:textSize="11sp" android:fontFamily="monospace"/>
        <EditText
            android:id="@+id/etAge"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="[Numeric]"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:textColorHint="#446677"
            android:background="@drawable/btn_outline"
            android:paddingStart="12dp"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GEN_CATEGORY:" android:textColor="#00FFCC" android:textSize="11sp" android:fontFamily="monospace"/>
        <Spinner
            android:id="@+id/spinnerGender"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/btn_outline"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnGenerateReport"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="INITIALIZE_SCAN_REPORT"
            android:textColor="#000000"
            android:background="#00FFCC"
            android:fontFamily="monospace"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
