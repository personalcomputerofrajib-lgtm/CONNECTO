<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00000F"
    tools:context=".MainActivity">

    <!-- TOP BAR -->
    <TextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CONNECTO"
        android:textColor="#00FFFF"
        android:textSize="20sp"
        android:letterSpacing="0.3"
        android:fontFamily="sans-serif-black"
        android:layout_marginTop="48dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <Button
        android:id="@+id/btnToggleView"
        android:layout_width="90dp"
        android:layout_height="36dp"
        android:text="BACK"
        android:textColor="#00FFFF"
        android:textSize="11sp"
        android:background="@drawable/btn_outline"
        android:layout_marginTop="44dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- MODE BUTTONS -->
    <LinearLayout
        android:id="@+id/modeBar"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/appTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnTap"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="TAP"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:background="#00FFCC"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnPaint"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="PAINT"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:background="#333355"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnMulti"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="MULTI"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:background="#333355"/>

    </LinearLayout>

    <!-- BODY MAP -->
    <com.connecto.app.ui.BodyMapView
        android:id="@+id/bodyMapView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/modeBar"
        app:layout_constraintBottom_toTopOf="@id/regionInfoCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- REGION INFO CARD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/regionInfoCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="4dp"
        app:cardBackgroundColor="#0D1B2A"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toTopOf="@id/actionBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/regionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Region"
                android:textColor="#00FFCC"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/regionMedical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medical Name"
                android:textColor="#AAAACC"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/regionSide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Side · Orientation"
                android:textColor="#778899"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/selectionCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 area(s) selected"
                android:textColor="#00FFCC"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ACTION BAR (BOTTOM) -->
    <LinearLayout
        android:id="@+id/actionBar"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="#0A0A1A"
        android:padding="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="CLEAR"
            android:textColor="#FF4444"
            android:textSize="11sp"
            android:background="#1A0000"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnUndo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="UNDO"
            android:textColor="#FFBB00"
            android:textSize="11sp"
            android:background="#1A1000"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnReport"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:text="GENERATE REPORT"
            android:textColor="#000000"
            android:textSize="11sp"
            android:background="#00FFCC"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
