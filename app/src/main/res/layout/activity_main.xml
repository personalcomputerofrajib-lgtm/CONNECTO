<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/hud_grid_bg"
    tools:context=".MainActivity">

    <!-- DATA OVERLAY: DNA STRANDS (Left) -->
    <ImageView
        android:layout_width="32dp"
        android:layout_height="240dp"
        android:src="@drawable/hud_dna_strand"
        android:alpha="0.3"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- DATA OVERLAY: DNA STRANDS (Right) -->
    <ImageView
        android:layout_width="32dp"
        android:layout_height="240dp"
        android:src="@drawable/hud_dna_strand"
        android:rotation="180"
        android:alpha="0.3"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- TOP BAR: HUD STYLE -->
    <RelativeLayout
        android:id="@+id/topHud"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingTop="32dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/appTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONNECTO HUD_v1.0"
            android:textColor="#00FFFF"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.2"/>

        <ImageButton
            android:id="@+id/btnHistory"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_toStartOf="@id/btnToggleView"
            android:src="@android:drawable/ic_menu_recent_history"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#00FFFF"
            android:layout_marginEnd="12dp"/>

        <Button
            android:id="@+id/btnToggleView"
            android:layout_width="80dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:text="BACK_VIEW"
            android:textColor="#00FFFF"
            android:textSize="10sp"
            android:background="@drawable/btn_outline"/>
    </RelativeLayout>

    <!-- LAYER BAR (NEW) -->
    <LinearLayout
        android:id="@+id/layerBar"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/topHud">

        <TextView android:id="@+id/tabSkin" android:layout_width="wrap_content" android:layout_height="match_parent" android:text=" [ SKIN ] " android:textColor="#00FFCC" android:textSize="11sp" android:gravity="center" android:fontFamily="monospace"/>
        <TextView android:id="@+id/tabMuscles" android:layout_width="wrap_content" android:layout_height="match_parent" android:text="  MUSCLES  " android:textColor="#446677" android:textSize="11sp" android:gravity="center" android:fontFamily="monospace"/>
        <TextView android:id="@+id/tabOrgans" android:layout_width="wrap_content" android:layout_height="match_parent" android:text="  ORGANS  " android:textColor="#446677" android:textSize="11sp" android:gravity="center" android:fontFamily="monospace"/>
        <TextView android:id="@+id/tabBones" android:layout_width="wrap_content" android:layout_height="match_parent" android:text="  SKELETAL " android:textColor="#446677" android:textSize="11sp" android:gravity="center" android:fontFamily="monospace"/>

    </LinearLayout>

    <!-- MODE BUTTONS -->
    <LinearLayout
        android:id="@+id/modeBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/layerBar"
        app:layout_constraintBottom_toTopOf="@id/regionInfoCard"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton android:id="@+id/btnTap" android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_mylocation" android:background="#00FFCC" android:layout_marginBottom="8dp" android:tint="#000000"/>
        <ImageButton android:id="@+id/btnPaint" android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_edit" android:background="#333355" android:layout_marginBottom="8dp" android:tint="#FFFFFF"/>
        <ImageButton android:id="@+id/btnMulti" android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_add" android:background="#333355" android:tint="#FFFFFF"/>

    </LinearLayout>

    <!-- BODY MAP -->
    <com.connecto.app.ui.BodyMapView
        android:id="@+id/bodyMapView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/layerBar"
        app:layout_constraintBottom_toTopOf="@id/regionInfoCard"
        app:layout_constraintStart_toEndOf="@id/modeBar"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- HUD GAUGES -->
    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/hud_gauge"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/hud_gauge"
        android:layout_margin="16dp"
        android:rotation="180"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- REGION INFO HUD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/regionInfoCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_margin="12dp"
        app:cardBackgroundColor="#CC0D1B2A"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/actionBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">
            <TextView android:id="@+id/regionLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="REG_ID: 00" android:textColor="#00FFFF" android:textSize="13sp" android:fontFamily="monospace"/>
            <TextView android:id="@+id/regionMedical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ANATOMICAL_MAP" android:textColor="#AAAACC" android:textSize="11sp" android:fontFamily="monospace"/>
            <TextView android:id="@+id/regionSide" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="COORD_SYS: R_ANT" android:textColor="#778899" android:textSize="10sp" android:fontFamily="monospace"/>
            <TextView android:id="@+id/selectionCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ACTIVE_NODES: 0" android:textColor="#00FFCC" android:textSize="10sp" android:layout_marginTop="2dp" android:fontFamily="monospace"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ACTION BAR -->
    <LinearLayout
        android:id="@+id/actionBar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#990A0A1A"
        android:padding="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <Button android:id="@+id/btnClear" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="PURGE" android:textColor="#FF4444" android:textSize="10sp" android:background="#1A0000" android:layout_marginEnd="4dp" android:fontFamily="monospace"/>
        <Button android:id="@+id/btnUndo" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="REVERT" android:textColor="#FFBB00" android:textSize="10sp" android:background="#1A1000" android:layout_marginEnd="4dp" android:fontFamily="monospace"/>
        <Button android:id="@+id/btnReport" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="2" android:text="GENERATE_LOG" android:textColor="#000000" android:textSize="10sp" android:background="#00FFCC" android:fontFamily="monospace"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
