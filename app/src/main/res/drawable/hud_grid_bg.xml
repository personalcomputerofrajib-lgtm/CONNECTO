<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:startColor="#0A1F2A"
                android:centerColor="#040F1A"
                android:endColor="#00050F"
                android:centerX="0.5"
                android:centerY="0.5"/>
        </shape>
    </item>

    <!-- Scientific HUD Outlines -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#1A3A4A" />
        </shape>
    </item>

    <!-- Subtle HUD Detail -->
    <item android:top="40dp" android:bottom="40dp" android:left="40dp" android:right="40dp">
        <shape android:shape="rectangle">
            <stroke android:width="0.5dp" android:color="#0D2A3A" />
        </shape>
    </item>
</layer-list>
